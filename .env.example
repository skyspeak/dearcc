# dear[CC] Field Report + The Letter (Vercel)
# Copy to .env.local for local dev. Set the same keys in the Vercel project.
# Never commit real secrets.

# --- Database (Neon Postgres, pooled URL) ---
DATABASE_URL=

# Unpooled URL for migrations (optional; defaults to DATABASE_URL with -pooler stripped)
# DIRECT_URL=

# --- Email (Resend) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL="dear[CC] The Letter <onboarding@resend.dev>"
# RESEND_REPLY_TO_EMAIL=

# Public site URL for unsubscribe links (Vercel production URL or custom domain)
BASE_URL=http://localhost:5173

# --- Cron ---
# openssl rand -hex 32
CRON_SECRET=

# --- Optional Gemini personalization ---
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
